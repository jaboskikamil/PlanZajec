@page "/"

<PageTitle>Elektroniczny Plan Zajęć</PageTitle>

<div class="container text-center mt-5">
    <h1 class="display-4 mb-4">Witaj w Elektronicznym Planie Zajęć</h1>
    <p class="lead mb-5">Wybierz sposób przeglądania planu:</p>

    <div class="row justify-content-center">
        <div class="col-md-4">
            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Wykładowcy</h5>
                    <p class="card-text">Przeglądaj plan zajęć według wykładowcy.</p>
                    <a href="/lecturers" class="btn btn-primary btn-lg w-100">Wybierz Wykładowcę</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-4 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Grupy</h5>
                    <p class="card-text">Przeglądaj plan zajęć według grupy dziekańskiej.</p>
                    <a href="/groups" class="btn btn-success btn-lg w-100">Wybierz Grupę</a>
                </div>
            </div>
        </div>
    </div>
</div>
